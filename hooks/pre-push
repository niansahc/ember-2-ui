#!/usr/bin/env bash
# Pre-push hook — blocks pushes during US Eastern business hours.
# Install: cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

python_bin=""
for cand in python3 python py; do
  if command -v "$cand" >/dev/null 2>&1; then
    python_bin="$cand"
    break
  fi
done

if [ -z "$python_bin" ]; then
  echo "pre-push: python not found in PATH — allowing push."
  exit 0
fi

"$python_bin" - <<'PY'
from datetime import datetime
from zoneinfo import ZoneInfo
import sys

now = datetime.now(ZoneInfo("America/New_York"))
# Monday=0 ... Sunday=6
if now.weekday() < 5 and 9 <= now.hour < 17:
    sys.stderr.write(
        "\nPush blocked during US East business hours (9am-5pm ET Mon-Fri). "
        "Commit locally and push after 5pm.\n"
        f"Current ET: {now.strftime('%A %H:%M %Z')}\n\n"
    )
    sys.exit(1)
sys.exit(0)
PY
