# Ember-2 API connection
VITE_EMBER_API_URL=http://localhost:8000/v1

# Ember-2 API key — required for authenticated endpoints
# Find your key by running: python scripts/set_api_key.py (in the ember-2 repo)
# Or retrieve it from Windows Credential Manager: ember-2 / api_key
VITE_EMBER_API_KEY=your_ember_api_key_here

# GitHub personal access token — used for bug reports (GitHub Issues API)
VITE_GITHUB_TOKEN=your_github_personal_access_token
